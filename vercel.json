{
  "version": 2,
  "functions": {
    "api/chat.js": { "memory": 1024, "maxDuration": 30 },
    "api/history.js": { "memory": 512, "maxDuration": 10 }
  },
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/history", "dest": "/api/history.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
